# Neon Postgres connection string (from console.neon.tech project dashboard)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require

# Any long random string — signs session cookies. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# The static site's real deployed origin (scheme+host, no trailing slash).
# Must match exactly — CORS with credentials cannot use a wildcard.
ALLOWED_ORIGIN=https://www.imprint-diamond.com

# Used to build password-reset links.
SITE_URL=https://www.imprint-diamond.com

# Optional — password-reset emails silently no-op (just logged) without this.
RESEND_API_KEY=
RESET_EMAIL_FROM=noreply@imprint-diamond.com

# Optional — gates registration behind an invite code. Leave both unset to
# allow open signup (V3's current register.html doesn't collect an invite
# code field, so leave these unset unless that UI gets added too).
REQUIRE_INVITE_CODE=0
REGISTRATION_INVITE_CODE=

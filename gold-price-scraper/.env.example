# Same Neon connection string used by the /backend project — this scraper
# and the backend API must point at the same database.
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require
# Set this in Vercel's project env vars too — Vercel then auto-sends
# `Authorization: Bearer <value>` on every Cron-triggered request, which
# api/scrape-gold.js checks. Generate any long random string.
CRON_SECRET=

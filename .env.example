# Supabase Postgres — powers /api/auth/*, /api/orders, admin (see app/database.py).
#
# Dashboard → Project Settings → Database → Connection string
#
# FastAPI on Render (long-lived): **Session pooler** (5432) or Direct connection
#   postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
#
# Direct (db.*) can be IPv6-only — if local connect fails on Windows, use Session pooler above.
#   postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Optional — for Supabase client SDK / future features (not required for raw SQL today)
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Any long random string — signs the session cookie. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Optional — gates registration behind an invite code.
# Set REQUIRE_INVITE_CODE=1 to require a valid DB invite code on register.html.
REQUIRE_INVITE_CODE=0
REGISTRATION_INVITE_CODE=

# Neon Postgres connection string (from console.neon.tech project dashboard).
# Powers /api/auth/* and /api/orders — see app/database.py, app/auth.py.
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require

# Any long random string — signs the session cookie. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Optional — gates registration behind an invite code.
# Set REQUIRE_INVITE_CODE=1 to require a valid DB invite code on register.html.
REQUIRE_INVITE_CODE=0
REGISTRATION_INVITE_CODE=
